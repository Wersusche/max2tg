# This file is for the Russian max-bridge node.
# The foreign tg-relay node gets its own .env content via FOREIGN_RELAY_ENV_B64.

APP_ROLE=max-bridge

# Shared secret used by the bridge and relay internal HTTP API.
RELAY_SHARED_SECRET=change_me_to_a_long_random_secret

# Max credentials (DevTools -> Application -> Local Storage -> web.max.ru)
MAX_TOKEN=your___oneme_auth_value
MAX_DEVICE_ID=your___oneme_device_id_value
# Optional: comma-separated Max chat IDs to listen to. Leave unset for all chats.
# MAX_CHAT_IDS=-123,-456

# Enable replies from Telegram topics back to Max.
REPLY_ENABLED=true

# Debug mode: verbose logs + JSON dump to debug/ (true/false)
DEBUG=false

# Local tunnel endpoint used by max-bridge to talk to tg-relay over SSH.
RELAY_TUNNEL_LOCAL_PORT=18080
# Optional: must match tg-relay if you changed RELAY_BIND_PORT there.
# RELAY_BIND_PORT=8080

# Foreign server SSH access for idempotent deploy + tunnel.
FOREIGN_SSH_HOST=relay.example.com
FOREIGN_SSH_PORT=22
FOREIGN_SSH_USER=deploy
# Safe for .env / docker compose env_file: quote the whole value when using \n escapes.
# Raw multiline input also works if your environment source preserves real line breaks.
FOREIGN_SSH_PRIVATE_KEY="-----BEGIN OPENSSH PRIVATE KEY-----\n...\n-----END OPENSSH PRIVATE KEY-----"
FOREIGN_APP_DIR=/home/relay/max2tg

# If false, max-bridge skips uploading the relay bundle and only opens the tunnel.
REMOTE_DEPLOY_ENABLED=true

# Base64-encoded contents of the foreign tg-relay .env file.
# Start from .env.relay.example and encode it as a single line.
FOREIGN_RELAY_ENV_B64=UEFTVEVfQkFTRTY0X1JFTEFZX0VOVl9IRVJF

# Optional local log dir override inside the container.
# LOG_DIR=/app/logs
