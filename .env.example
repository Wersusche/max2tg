# Max credentials (DevTools → Application → Local Storage → web.max.ru)
MAX_TOKEN=your___oneme_auth_value
MAX_DEVICE_ID=your___oneme_device_id_value
# (Optional) Max chat ids to listen, comma-separated
MAX_CHAT_IDS=-123,-456

# Telegram (получить у @BotFather; узнать свой chat_id через @userinfobot)
TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TG_CHAT_ID=123456789

# Debug mode: подробные логи + дамп JSON в debug/ (true/false)
DEBUG=false

# Разрешить ответы из Telegram в Max (true/false)
REPLY_ENABLED=false
