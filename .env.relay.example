APP_ROLE=tg-relay

# Must match the bridge node.
RELAY_SHARED_SECRET=change_me_to_a_long_random_secret

# Telegram relay settings
TG_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
TG_CHAT_ID=-1001234567890

# tg-relay runs inside Docker, so bind to all interfaces in the container.
# docker-compose still publishes it only on 127.0.0.1 of the foreign host.
RELAY_BIND_HOST=0.0.0.0
RELAY_BIND_PORT=8080
# Optional: change only the foreign host port if 127.0.0.1:8080 is already busy.
# max-bridge will auto-read it from FOREIGN_RELAY_ENV_B64 during remote deploy.
# RELAY_HOST_PORT=18080

# Persistent SQLite stores on the relay node
TOPIC_DB_PATH=data/topics.sqlite3
COMMAND_DB_PATH=data/commands.sqlite3

# Enable Telegram polling to collect topic replies back to Max.
REPLY_ENABLED=true

# Optional
DEBUG=false
